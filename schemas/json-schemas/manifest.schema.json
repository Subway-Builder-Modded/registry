{
  "$ref": "#/definitions/manifest",
  "definitions": {
    "manifest": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "schema_version": {
              "type": "number",
              "const": 1
            },
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "author": {
              "type": "string",
              "minLength": 1
            },
            "github_id": {
              "type": "integer",
              "minimum": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "gallery": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "is_test": {
              "type": "boolean"
            },
            "source": {
              "type": "string",
              "format": "uri"
            },
            "update": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "github"
                    },
                    "repo": {
                      "type": "string",
                      "pattern": "^[^/]+\\/[^/]+$"
                    }
                  },
                  "required": [
                    "type",
                    "repo"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "custom"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "required": [
                    "type",
                    "url"
                  ],
                  "additionalProperties": false
                }
              ]
            },
            "city_code": {
              "type": "string",
              "pattern": "^[A-Z0-9]{2,4}$"
            },
            "country": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            },
            "population": {
              "type": "integer",
              "minimum": 0
            },
            "residents_total": {
              "type": "integer",
              "minimum": 0
            },
            "points_count": {
              "type": "integer",
              "minimum": 0
            },
            "population_count": {
              "type": "integer",
              "minimum": 0
            },
            "initial_view_state": {
              "type": "object",
              "properties": {
                "latitude": {
                  "type": "number"
                },
                "longitude": {
                  "type": "number"
                },
                "zoom": {
                  "type": "number"
                },
                "bearing": {
                  "type": "number"
                }
              },
              "required": [
                "latitude",
                "longitude",
                "zoom",
                "bearing"
              ],
              "additionalProperties": false
            },
            "grid_statistics": {
              "type": "object",
              "properties": {
                "residentWeightedNearestNeighborKm": {
                  "type": "object",
                  "properties": {
                    "p10": {
                      "type": "number"
                    },
                    "p25": {
                      "type": "number"
                    },
                    "p50": {
                      "type": "number"
                    },
                    "p75": {
                      "type": "number"
                    },
                    "p90": {
                      "type": "number"
                    },
                    "mean": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "p10",
                    "p25",
                    "p50",
                    "p75",
                    "p90",
                    "mean"
                  ],
                  "additionalProperties": false
                },
                "workerWeightedNearestNeighborKm": {
                  "type": "object",
                  "properties": {
                    "p10": {
                      "type": "number"
                    },
                    "p25": {
                      "type": "number"
                    },
                    "p50": {
                      "type": "number"
                    },
                    "p75": {
                      "type": "number"
                    },
                    "p90": {
                      "type": "number"
                    },
                    "mean": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "p10",
                    "p25",
                    "p50",
                    "p75",
                    "p90",
                    "mean"
                  ],
                  "additionalProperties": false
                },
                "commuteDistanceKm": {
                  "type": "object",
                  "properties": {
                    "p10": {
                      "type": "number"
                    },
                    "p25": {
                      "type": "number"
                    },
                    "p50": {
                      "type": "number"
                    },
                    "p75": {
                      "type": "number"
                    },
                    "p90": {
                      "type": "number"
                    },
                    "mean": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "p10",
                    "p25",
                    "p50",
                    "p75",
                    "p90",
                    "mean"
                  ],
                  "additionalProperties": false
                },
                "residentCellDensity": {
                  "type": "object",
                  "properties": {
                    "p10": {
                      "type": "number"
                    },
                    "p25": {
                      "type": "number"
                    },
                    "p50": {
                      "type": "number"
                    },
                    "p75": {
                      "type": "number"
                    },
                    "p90": {
                      "type": "number"
                    },
                    "mean": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "p10",
                    "p25",
                    "p50",
                    "p75",
                    "p90",
                    "mean"
                  ],
                  "additionalProperties": false
                },
                "workerCellDensity": {
                  "type": "object",
                  "properties": {
                    "p10": {
                      "type": "number"
                    },
                    "p25": {
                      "type": "number"
                    },
                    "p50": {
                      "type": "number"
                    },
                    "p75": {
                      "type": "number"
                    },
                    "p90": {
                      "type": "number"
                    },
                    "mean": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "p10",
                    "p25",
                    "p50",
                    "p75",
                    "p90",
                    "mean"
                  ],
                  "additionalProperties": false
                },
                "detail": {
                  "type": "object",
                  "properties": {
                    "radiusKm": {
                      "type": "number"
                    },
                    "expectedPointSpacingKm": {
                      "type": "number"
                    },
                    "normalizedRadius": {
                      "type": "number"
                    },
                    "activityPerPoint": {
                      "type": "number"
                    },
                    "playableAreaKm2": {
                      "type": "number"
                    },
                    "playableAreaPerPointKm2": {
                      "type": "number"
                    },
                    "playableCatchmentRadiusKm": {
                      "type": "number"
                    },
                    "localityScore": {
                      "type": "number"
                    },
                    "deaggregationScore": {
                      "type": "number"
                    },
                    "score": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "radiusKm",
                    "expectedPointSpacingKm",
                    "normalizedRadius",
                    "activityPerPoint",
                    "playableAreaKm2",
                    "playableAreaPerPointKm2",
                    "playableCatchmentRadiusKm",
                    "localityScore",
                    "deaggregationScore",
                    "score"
                  ],
                  "additionalProperties": false
                },
                "polycentrism": {
                  "type": "object",
                  "properties": {
                    "activity": {
                      "type": "object",
                      "properties": {
                        "score": {
                          "type": "number"
                        },
                        "continuousScore": {
                          "type": "number"
                        },
                        "detectedCenterCount": {
                          "type": "number"
                        },
                        "effectiveCenterCount": {
                          "type": "number"
                        },
                        "largestCenterShare": {
                          "type": "number"
                        },
                        "bandwidthKm": {
                          "type": "number"
                        },
                        "reliabilityScore": {
                          "type": "number"
                        },
                        "supportLevel": {
                          "type": "string",
                          "enum": [
                            "low",
                            "medium",
                            "high"
                          ]
                        },
                        "usedFallback": {
                          "type": "boolean"
                        },
                        "topCenters": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "longitude": {
                                "type": "number"
                              },
                              "latitude": {
                                "type": "number"
                              },
                              "massShare": {
                                "type": "number"
                              },
                              "assignedMass": {
                                "type": "number"
                              },
                              "assignedPointCount": {
                                "type": "number"
                              },
                              "prominenceRatio": {
                                "type": "number"
                              }
                            },
                            "required": [
                              "longitude",
                              "latitude",
                              "massShare",
                              "assignedMass",
                              "assignedPointCount",
                              "prominenceRatio"
                            ],
                            "additionalProperties": false
                          }
                        },
                        "debug": {}
                      },
                      "required": [
                        "score",
                        "continuousScore",
                        "detectedCenterCount",
                        "effectiveCenterCount",
                        "largestCenterShare",
                        "bandwidthKm",
                        "reliabilityScore",
                        "supportLevel",
                        "usedFallback",
                        "topCenters"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "activity"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "residentWeightedNearestNeighborKm",
                "workerWeightedNearestNeighborKm",
                "commuteDistanceKm",
                "residentCellDensity",
                "workerCellDensity",
                "detail",
                "polycentrism"
              ],
              "additionalProperties": false
            },
            "data_source": {
              "type": "string",
              "minLength": 1
            },
            "source_quality": {
              "type": "string",
              "enum": [
                "low-quality",
                "medium-quality",
                "high-quality"
              ]
            },
            "level_of_detail": {
              "type": "string",
              "enum": [
                "low-detail",
                "medium-detail",
                "high-detail"
              ]
            },
            "location": {
              "type": "string",
              "enum": [
                "caribbean",
                "central-america",
                "central-asia",
                "east-africa",
                "east-asia",
                "europe",
                "middle-east",
                "north-africa",
                "north-america",
                "oceania",
                "south-america",
                "south-asia",
                "southeast-asia",
                "southern-africa",
                "west-africa"
              ]
            },
            "special_demand": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "airports",
                  "entertainment",
                  "ferries",
                  "hospitals",
                  "parks",
                  "schools",
                  "universities"
                ]
              }
            },
            "file_sizes": {
              "type": "object",
              "additionalProperties": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "required": [
            "schema_version",
            "id",
            "name",
            "author",
            "github_id",
            "description",
            "tags",
            "gallery",
            "is_test",
            "source",
            "update",
            "city_code",
            "country",
            "population",
            "residents_total",
            "points_count",
            "population_count",
            "initial_view_state",
            "data_source",
            "source_quality",
            "level_of_detail",
            "location",
            "special_demand",
            "file_sizes"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "schema_version": {
              "type": "number",
              "const": 1
            },
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "author": {
              "type": "string",
              "minLength": 1
            },
            "github_id": {
              "type": "integer",
              "minimum": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "gallery": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "is_test": {
              "type": "boolean"
            },
            "source": {
              "type": "string",
              "format": "uri"
            },
            "update": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "github"
                    },
                    "repo": {
                      "type": "string",
                      "pattern": "^[^/]+\\/[^/]+$"
                    }
                  },
                  "required": [
                    "type",
                    "repo"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "custom"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "required": [
                    "type",
                    "url"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          },
          "required": [
            "schema_version",
            "id",
            "name",
            "author",
            "github_id",
            "description",
            "tags",
            "gallery",
            "is_test",
            "source",
            "update"
          ],
          "additionalProperties": false
        }
      ]
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
