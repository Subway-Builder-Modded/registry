{
  "$ref": "#/definitions/mod-manifest",
  "definitions": {
    "mod-manifest": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "number",
          "const": 1
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "github_id": {
          "type": "integer",
          "minimum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "is_test": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "format": "uri"
        },
        "update": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "github"
                },
                "repo": {
                  "type": "string",
                  "pattern": "^[^/]+\\/[^/]+$"
                }
              },
              "required": [
                "type",
                "repo"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "custom"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "type",
                "url"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "schema_version",
        "id",
        "name",
        "author",
        "github_id",
        "description",
        "tags",
        "gallery",
        "is_test",
        "source",
        "update"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
